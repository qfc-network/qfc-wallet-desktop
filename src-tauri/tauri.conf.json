{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QFC Wallet",
  "version": "1.0.0",
  "identifier": "network.qfc.wallet",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "QFC Wallet",
        "width": 400,
        "height": 600,
        "resizable": true,
        "minWidth": 360,
        "minHeight": 500,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "targets": ["dmg", "app"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {}

}
